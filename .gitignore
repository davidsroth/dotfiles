# macOS
.DS_Store

# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# Tmux plugins (managed by TPM)
core/.config/tmux/plugins/tpm/
core/.config/tmux/plugins/tmux-yank/
core/.config/tmux/plugins/tmux-sessionist/
core/.config/tmux/plugins/tmux-fzf/

# Hammerspoon
core/.hammerspoon/bin/*
!core/.hammerspoon/bin/.gitkeep
core/.hammerspoon/Spoons/*
!core/.hammerspoon/Spoons/.gitkeep

# Karabiner generated backups (not for version control)
core/.config/karabiner/automatic_backups/

# Editor temporary files
*.swp
*.swo
*~
.netrwhist

# Local overrides
*.local
*.local.lua
!*.local.example
core/.config/nvim/.luarc.json
core/.config/gh-dash/config.local.yml

# Logs
.nvimlog
lazygit_error.log
nvim-profile*.log

# Bundles
*.bundle

# Claude Agent / AI Memory
core/.claude/
core/.codex/

# Notes (Personal vault)
notes/

# App Configs (ignoring potentially sensitive or large generated dirs)
core/.config/raycast/
core/.config/sunsama/
core/.config/op/

# Root level dotfiles that might be stow conflicts or local
.gitconfig
core/.config/espanso/config/local.yml
core/.config/espanso/match/local.yml
core/.config/espanso/.local_email
core/.config/espanso/.local_address
core/.config/gh/hosts.yml

# OpenCode vendored dependencies (installed via post-install)
core/.config/opencode/node_modules/

# Local fork of @juicesharp/rpiv-mono used by pi (machine-local; see settings.json)
pi/packages/rpiv-mono/

# Machine-specific configurations
core/.config/gh/config.yml
core/.config/k9s/config.yaml
core/.config/gh-dash/config.yml

# Neovim lazy-lock should be tracked (managed in stow package)
!core/.config/nvim/lazy-lock.json

# Symlink to shared .agent/skills (created by install.sh)
pi/.pi/agent/skills

# Systemd enable symlinks (absolute, machine-specific)
core/.config/systemd/user/default.target.wants/

# Bitwarden CLI (contains credentials/session data)
.config/Bitwarden CLI/

# Claude Code project data (track settings only)
.claude/*
!.claude/settings.json
!.claude/commands/
!.claude/memory/
