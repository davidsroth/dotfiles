# Standard stow ignores (replaces defaults when this file is present)
RCS
CVS
\.svn
\.git
_darcs
\.hg
\.#.*
#.*

# Generated per-machine file — managed by `just pi-settings`, not stowed
^\.pi/agent/settings\.json$

# Memory dir is a mix of tracked (MEMORY.md) and per-machine local files.
# install.sh / `just pi-memory` symlinks MEMORY.md explicitly; don't let stow
# fold the whole dir (which would swallow local MEMORY.local.md/SCRATCHPAD/daily).
^\.pi/agent/memory/
