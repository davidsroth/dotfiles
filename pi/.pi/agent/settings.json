  "defaultModel": "Kimi-K2.6",
  "terminal": {
    "showTerminalProgress": true
  },
  "quietStartup": true,
  "packages": [
    "../../packages/pi-vim",
    "../../packages/pi-subagents",
    "../../packages/pi-btw",
    "../../packages/pi-intercom",
    "../../packages/rpiv-mono/packages/rpiv-ask-user-question",
    "npm:@feniix/pi-notion@2.2.2",
    "npm:pi-web-access"
  ],
  "hideThinkingBlock": false,
  "enabledModels": [
    "anthropic/claude-opus-4-7",
    "anthropic/claude-sonnet-4-6",
    "openai/gpt-5.5",
    "openai/gpt-5.4",
    "openai/gpt-5.4-mini",
    "google/gemini-3.1-pro-preview",
    "azure-foundry/Kimi-K2.6"
