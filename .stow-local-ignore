# Stow ignore file
# Files and patterns listed here will be ignored by GNU Stow

# Documentation files
^CLAUDE\.md$
README.md
README.*

# Version control
\.git
\.gitignore
\.gitmodules

# macOS system files
\.DS_Store

# Editor temporary files
.*\.swp
.*\.swo
.*~

# Stow metadata
\.stow-local-ignore
\.stowrc

# Other common files to ignore
LICENSE
LICENSE.*
CONTRIBUTING.*

# Installation and setup scripts
install.sh
bootstrap.sh
macos-defaults.sh
justfile
Justfile

# Package management
Brewfile
Brewfile.lock.json

# Repo-level automation and reports (do not stow into $HOME)
^\.codex$

# Logs and transient files that should never be stowed
^.nvimlog$

# Repo-level files that should not be stowed into $HOME
.*\.bundle$

# Example files
.*\.example$
.*\.example\..*$

# Local, host-specific configs that should never be stowed.
# Covers the canonical path plus any nested ".claude/.claude/" subtree that
# can accumulate when Claude Code runs inside a stowed .claude dir.
^\.claude/settings\.local\.json$
\.claude/\.claude/
^\.config/gh-dash/config\.local\.yml$
^\.config/gh-dash/config\.local\.example\.yml$
.*\.local\.lua$
